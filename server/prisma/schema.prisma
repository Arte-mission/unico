generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  university String  @default("Macquarie University")
  skills    String   @default("[]") // Stored as JSON string
  intent    String?  // Build/Learn/Explore
  createdAt DateTime @default(now())

  // Relations
  projectsOwned Project[] @relation("ProjectOwner")
  memberships   ProjectMember[]
  progressLogs  ProgressLog[]
  following     Follower[]
  sentMessages  Message[] @relation("MessageSender")
  connectionsFrom Connection[] @relation("ConnectionFrom")
  connectionsTo   Connection[] @relation("ConnectionTo")
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  createdBy   String
  createdAt   DateTime @default(now())
  lastUpdated DateTime @default(now()) @updatedAt

  // Relations
  owner       User     @relation("ProjectOwner", fields: [createdBy], references: [id])
  members     ProjectMember[]
  progressLogs ProgressLog[]
  followers   Follower[]
  messages    Message[] @relation("ProjectMessages")
}

model ProjectMember {
  id              String   @id @default(uuid())
  userId          String
  projectId       String
  role            String   // e.g., "Developer", "Designer", "Founder"
  commitmentLevel String?  // e.g., "Part-time", "Full-time"
  joinedAt        DateTime @default(now())

  // Relations
  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
}

model ProgressLog {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  content   String
  mediaUrl  String?
  createdAt DateTime @default(now())

  // Relations
  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

model Follower {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())

  // Relations
  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String?  // User ID for DM, can be null if projectId is set
  projectId  String?  // For project group chats
  content    String
  createdAt  DateTime @default(now())

  // Relations
  sender  User     @relation("MessageSender", fields: [senderId], references: [id])
  project Project? @relation("ProjectMessages", fields: [projectId], references: [id])
}

model Connection {
  id              String   @id @default(uuid())
  userId          String
  connectedUserId String
  strengthScore   Int      @default(0) // Mock AI score
  createdAt       DateTime @default(now())

  // Relations
  user          User @relation("ConnectionFrom", fields: [userId], references: [id])
  connectedUser User @relation("ConnectionTo", fields: [connectedUserId], references: [id])

  @@unique([userId, connectedUserId])
}
