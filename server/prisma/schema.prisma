generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String          @id @default(uuid())
  name            String
  email           String          @unique
  password        String
  phone           String?
  university      String          @default("Macquarie University")
  skills          String          @default("[]")
  intent          String?
  createdAt       DateTime        @default(now())
  bio             String          @default("")
  lastActive      DateTime        @default(now())
  connectionsTo   Connection[]    @relation("ConnectionTo")
  connectionsFrom Connection[]    @relation("ConnectionFrom")
  joinRequests    JoinRequest[]
  sentMessages    Message[]       @relation("MessageSender")
  progressLogs    ProgressLog[]
  projectsOwned   Project[]       @relation("ProjectOwner")
  memberships     ProjectMember[]
}

model Project {
  id              String          @id @default(uuid())
  title           String
  description     String
  createdBy       String
  createdAt       DateTime        @default(now())
  lastUpdated     DateTime        @default(now()) @updatedAt
  validationScore Float           @default(0)
  joinRequests    JoinRequest[]
  messages        Message[]       @relation("ProjectMessages")
  progressLogs    ProgressLog[]
  owner           User            @relation("ProjectOwner", fields: [createdBy], references: [id])
  members         ProjectMember[]
}

model ProjectMember {
  id              String   @id @default(uuid())
  userId          String
  projectId       String
  role            String
  commitmentLevel String?
  joinedAt        DateTime @default(now())
  project         Project  @relation(fields: [projectId], references: [id])
  user            User     @relation(fields: [userId], references: [id])

  @@unique([userId, projectId])
}

model ProgressLog {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  content   String
  mediaUrl  String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model JoinRequest {
  id           String   @id @default(uuid())
  userId       String
  projectId    String
  message      String
  contribution String
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, projectId])
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String?
  projectId  String?
  content    String
  createdAt  DateTime @default(now())
  project    Project? @relation("ProjectMessages", fields: [projectId], references: [id])
  sender     User     @relation("MessageSender", fields: [senderId], references: [id])
}

model Connection {
  id              String   @id @default(uuid())
  userId          String
  connectedUserId String
  strengthScore   Int      @default(0)
  createdAt       DateTime @default(now())
  connectedUser   User     @relation("ConnectionTo", fields: [connectedUserId], references: [id])
  user            User     @relation("ConnectionFrom", fields: [userId], references: [id])

  @@unique([userId, connectedUserId])
}
